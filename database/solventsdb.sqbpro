name="SQL 1*">SELECT s.name,
       MAX(g.diffusion_coefficient) / MIN(g.diffusion_coefficient) AS thermal_acceleration_ratio
FROM green_temperature_series g
JOIN solvents s
ON g.solvent_id = s.id
GROUP BY s.name
ORDER BY thermal_acceleration_ratio DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
